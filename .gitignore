# Root gitignore for weekly monorepo

# Virtual Environments & Dependencies
.venv/
venv/
ENV/
env/
node_modules/

# Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Reports, Downloads, Logs, and Spreadsheets
laporan/
downloads/
logs/
*.csv
*.xlsx
*.log

# OS files
.DS_Store
Thumbs.db
.git_backup/
*.git_backup/

# Credentials & Secrets
.env
.env.*
*credentials*.json
session.json
session_*.json
sessions/
shopee/sessions/
grab/sessions/

# Specific ignores for agency and VB folders to avoid pushing large local chrome profiles
agency/data/chrome_profile/
agency/data/chrome_profile_*
agency/data/*_cache.csv

VB/data/chrome_profile/
VB/data/chrome_profile_*/
VB/data/chrome_profiles/
VB/data/*_cache.csv

# Generic Chrome profile, cache, and DB ignores
**/chrome_profile*/
**/chrome_profiles*/
**/browser_data/
**/GrShaderCache/
**/GraphiteDawnCache/
**/ShaderCache/
**/Local State
**/first_party_sets.db
**/segmentation_platform/
**/shopee_profile*/
**/DawnGraphiteCache/
**/DawnWebGPUCache/
**/Extension State/
**/GCM Store/
**/IndexedDB/
**/Local Storage/
**/Session Storage/
**/Sessions/
**/Site Characteristics Database/
**/Sync Data/
**/TransportSecurity
**/WebStorage/
**/shared_proto_db/
**/Search Logos/
**/Dictionaries/
**/Extension Rules/
**/Extension Scripts/
**/Preferences
**/History*
**/Favicons*
**/DIPS*
**/BrowsingTopicsState*
**/Reporting and NEL
**/Network Action Predictor
**/Network Persistent State

